# Supabase / Postgres (required in production; local dev defaults to SQLite file if unset)
DATABASE_URL=postgresql://postgres:<PASSWORD>@db.<PROJECT_REF>.supabase.co:5432/postgres
# Alternative name supported by settings.py
# SUPABASE_DB_URL=postgresql://...

REDIS_URL=redis://localhost:6379/0

SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True

# Comma-separated hosts
ALLOWED_HOSTS=localhost,127.0.0.1

# Optional: restrict CORS when DEBUG=False
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional: Postgres SSL for non-Supabase hosts
# PG_SSLMODE=require

# Run concurrent payout test against Postgres (see README)
# FORCE_PG_TESTS=1
